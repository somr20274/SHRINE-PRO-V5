{% doc %}
  @prompt
    video, media a importer
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-media-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-media-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-media-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-media-caption-{{ ai_gen_id }} {
    padding: 16px;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-media-block-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-media-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<media-block-{{ ai_gen_id }}
  class="ai-media-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-media-container-{{ ai_gen_id }}">
    {% if block.settings.media_type == 'image' %}
      {% if block.settings.image != blank %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-media-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-media-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-media-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}
    {% elsif block.settings.media_type == 'video' %}
      {% if block.settings.video != blank %}
        {{ block.settings.video | video_tag:
          autoplay: block.settings.autoplay,
          loop: block.settings.loop,
          muted: block.settings.mute,
          controls: block.settings.show_controls,
          class: 'ai-media-video-' | append: ai_gen_id
        }}
      {% else %}
        <div class="ai-media-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-media-empty-state-{{ ai_gen_id }}">
            Next, add a video
          </div>
        </div>
      {% endif %}
    {% endif %}

    {% if block.settings.caption != blank %}
      <div class="ai-media-caption-{{ ai_gen_id }}">
        {{ block.settings.caption }}
      </div>
    {% endif %}
  </div>
</media-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-media-video-{{ ai_gen_id }}');
        if (video) {
          video.addEventListener('loadeddata', function() {
            console.log('Video loaded successfully');
          });
        }
      }
    }

    customElements.define('media-block-{{ ai_gen_id }}', MediaBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Media",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "select",
      "id": "caption_alignment",
      "label": "Caption alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Video playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false,
      "info": "Video will play automatically when loaded"
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Media"
    }
  ]
}
{% endschema %}
