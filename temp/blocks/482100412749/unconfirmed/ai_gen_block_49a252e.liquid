{% doc %}
  @prompt
    video
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #000000;
  }

  .ai-video-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<video-block-{{ ai_gen_id }}
  class="ai-video-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      {% liquid
        assign video_url = block.settings.video_url
        assign video_id = ''
        assign video_type = ''

        if video_url contains 'youtube.com' or video_url contains 'youtu.be'
          assign video_type = 'youtube'
          if video_url contains 'youtu.be/'
            assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
          elsif video_url contains 'watch?v='
            assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first
          elsif video_url contains 'embed/'
            assign video_id = video_url | split: 'embed/' | last | split: '?' | first
          endif
        elsif video_url contains 'vimeo.com'
          assign video_type = 'vimeo'
          assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first
        endif
      %}

      {% if video_type == 'youtube' and video_id != blank %}
        <iframe
          class="ai-video-iframe-{{ ai_gen_id }}"
          src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ block.settings.autoplay }}&mute={{ block.settings.mute }}&loop={{ block.settings.loop }}&controls={{ block.settings.show_controls }}&rel=0{% if block.settings.loop == 1 %}&playlist={{ video_id }}{% endif %}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      {% elsif video_type == 'vimeo' and video_id != blank %}
        <iframe
          class="ai-video-iframe-{{ ai_gen_id }}"
          src="https://player.vimeo.com/video/{{ video_id }}?autoplay={{ block.settings.autoplay }}&muted={{ block.settings.mute }}&loop={{ block.settings.loop }}&controls={{ block.settings.show_controls }}"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      {% else %}
        <div class="ai-video-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-video-empty-state-{{ ai_gen_id }}">
            Invalid video URL. Please enter a valid YouTube or Vimeo URL.
          </div>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-video-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-video-empty-state-{{ ai_gen_id }}">
          Next, add a video URL
        </div>
      </div>
    {% endif %}
  </div>
</video-block-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const iframe = this.querySelector('.ai-video-iframe-{{ ai_gen_id }}');
        if (iframe) {
          iframe.addEventListener('load', function() {
            console.log('Video loaded successfully');
          });
        }
      }
    }

    customElements.define('video-block-{{ ai_gen_id }}', VideoBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Paste a YouTube or Vimeo video URL"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25",
          "label": "16:9"
        },
        {
          "value": "75",
          "label": "4:3"
        },
        {
          "value": "100",
          "label": "1:1"
        },
        {
          "value": "125",
          "label": "4:5"
        }
      ],
      "default": "56.25"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false,
      "info": "Video will play automatically when loaded"
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show controls",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Video"
    }
  ]
}
{% endschema %}
