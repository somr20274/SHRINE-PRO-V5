    "collapsible_content_YiNgMx": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_eUkiL6": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Cómo funciona el limpiador a vapor?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>El dispositivo calienta el agua para generar vapor a alta presión. Este vapor elimina la suciedad, la grasa y las bacterias sin necesidad de productos químicos.</p>",
            "page": ""
          }
        },
        "collapsible_row_dV6Hny": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Necesito usar productos de limpieza?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>No, solo necesitas agua. El vapor es suficiente para limpiar y desinfectar eficazmente.</p>",
            "page": ""
          }
        },
        "collapsible_row_zyqXjG": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿En qué superficies se puede usar?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Puedes usarlo en múltiples superficies: cocina, baño, azulejos, juntas, sofás, colchones, ventanas, coche y más.</p>",
            "page": ""
          }
        },
        "collapsible_row_tmk4wz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Es seguro para niños y mascotas?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Sí, al no utilizar productos químicos es una opción más segura para hogares con niños y mascotas.</p>",
            "page": ""
          }
        },
        "collapsible_row_NWPtfW": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Cuánto tarda en calentarse?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>El dispositivo se calienta en pocos segundos, permitiendo un uso rápido y práctico en cualquier momento</p>",
            "page": ""
          }
        },
        "collapsible_row_kwCprL": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Elimina realmente bacterias?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Sí, el vapor a alta temperatura ayuda a eliminar bacterias y gérmenes de forma natural.</p>",
            "page": ""
          }
        },
        "collapsible_row_y9dQzx": {
          "type": "collapsible_row",
          "settings": {
            "heading": "¿Es fácil de usar?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Sí, es muy sencillo: llenar con agua, encender y limpiar. No requiere experiencia.</p>",
            "page": ""
          }
        },
        "collapsible_row_ggmFJm": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Cuánto dura el vapor?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Depende del uso, pero el depósito permite varios minutos de limpieza continua.</p>",
            "page": ""
          }
        },
        "collapsible_row_ytM8cJ": {
          "type": "collapsible_row",
          "disabled": true,
          "settings": {
            "heading": "¿Ofrecen garantía?",
            "icon": "check_box",
            "filled_icon": false,
            "row_content": "<p>Sí, ofrecemos una garantía de satisfacción de 30 días. Si no estás satisfecho, te devolvemos el dinero.</p>",
            "page": ""
          }
        }
      },
